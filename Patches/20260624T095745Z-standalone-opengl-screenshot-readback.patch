+void FSlateOpenGLRenderer::CapturePendingScreenshot( const SWindow* WindowToDraw, const FSlateOpenGLViewport& InViewport )
+{
+	if (ScreenshotState.WindowToCapture != WindowToDraw || !ScreenshotState.ColorData)
+	{
+		return;
+	}
+
+	TArray<FColor>* ColorData = ScreenshotState.ColorData;
+	const FIntRect ScreenshotRect = ScreenshotState.ViewRect;
+	ScreenshotState = {};
+
+	ColorData->Reset();
+
+	const int32 ViewportWidth = FMath::TruncToInt(InViewport.ViewportRect.Right - InViewport.ViewportRect.Left);
+	const int32 ViewportHeight = FMath::TruncToInt(InViewport.ViewportRect.Bottom - InViewport.ViewportRect.Top);
+	const FIntPoint OutputExtent(ViewportWidth, ViewportHeight);
+	FIntRect ViewRectClamped;
+	ViewRectClamped.Min = ScreenshotRect.Min;
+	ViewRectClamped.Max = ScreenshotRect.Max.ComponentMin(OutputExtent);
+	ViewRectClamped.Max = ScreenshotRect.Min.ComponentMax(ViewRectClamped.Max);
+
+	if (ViewRectClamped.IsEmpty())
+	{
+		return;
+	}
+
+	const int32 Width = ViewRectClamped.Width();
+	const int32 Height = ViewRectClamped.Height();
+	const int32 PixelCount = Width * Height;
+	TArray<uint8> RawPixels;
+	RawPixels.SetNumUninitialized(PixelCount * 4);
+
+	GLint PreviousPackAlignment = 0;
+	glGetIntegerv(GL_PACK_ALIGNMENT, &PreviousPackAlignment);
+	glPixelStorei(GL_PACK_ALIGNMENT, 1);
+	glReadPixels(ViewRectClamped.Min.X, ViewportHeight - ViewRectClamped.Max.Y, Width, Height, GL_RGBA, GL_UNSIGNED_BYTE, RawPixels.GetData());
+	const GLenum ReadError = glGetError();
+	glPixelStorei(GL_PACK_ALIGNMENT, PreviousPackAlignment);
+
+	if (ReadError != GL_NO_ERROR)
+	{
+		return;
+	}
+
+	ColorData->SetNumUninitialized(PixelCount);
+	for (int32 DestY = 0; DestY < Height; ++DestY)
+	{
+		const int32 SourceY = Height - 1 - DestY;
+		for (int32 X = 0; X < Width; ++X)
+		{
+			const int32 SourceIndex = (SourceY * Width + X) * 4;
+			(*ColorData)[DestY * Width + X] = FColor(
+				RawPixels[SourceIndex],
+				RawPixels[SourceIndex + 1],
+				RawPixels[SourceIndex + 2],
+				RawPixels[SourceIndex + 3]);
+		}
+	}
+}
