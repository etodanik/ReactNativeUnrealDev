/Programs/*/Saved/

# ignore build files
/Programs/*/Build/
/Programs/*/Build/UnrealGameSync.ini
/Programs/*/Build/UnrealGameSync.png
/Programs/*/Build/Windows/Application.ico

# ignore binary files inside Game/Plugins folder
